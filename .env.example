# ── Havilah OS Environment Configuration ───────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Database
HAVILAH_DB_HOST=localhost
HAVILAH_DB_PORT=5432
HAVILAH_DB_NAME=havilah
HAVILAH_DB_USER=havilah_app
HAVILAH_DB_PASSWORD=changeme
HAVILAH_DB_ECHO=false

# Application
HAVILAH_APP_NAME=Havilah OS
HAVILAH_APP_VERSION=0.1.0
HAVILAH_DEBUG=false
HAVILAH_ENV=development

# Security
HAVILAH_SECRET_KEY=changeme-to-random-string
HAVILAH_API_KEY_SALT=changeme-to-random-string
