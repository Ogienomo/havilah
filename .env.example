# Havilah OS — Environment Variables Template
# Copy this to .env and fill in your values. NEVER commit .env to git.

# ── Application ──────────────────────────────────────────────
HAVILAH_ENV=development
HAVILAH_DEBUG=true
HAVILAH_SECRET_KEY=change-me-to-a-strong-secret-in-production
HAVILAH_APP_NAME="Havilah OS"

# ── Database ─────────────────────────────────────────────────
HAVILAH_DB_HOST=localhost
HAVILAH_DB_PORT=5432
HAVILAH_DB_NAME=havilah
HAVILAH_DB_USER=havilah_app
HAVILAH_DB_PASSWORD=Havilah2026!

# ── OpenAI / Hermes ─────────────────────────────────────────
HAVILAH_OPENAI_API_KEY=sk-your-openai-key-here
HAVILAH_OPENAI_MODEL=gpt-4o
HAVILAH_OPENAI_MAX_TOKENS=4096
HAVILAH_OPENAI_TEMPERATURE=0.7
HAVILAH_OPENAI_BASE_URL=
HAVILAH_HERMES_ENABLED=true

# ── WhatsApp Business API ───────────────────────────────────
HAVILAH_WHATSAPP_ENABLED=false
HAVILAH_WHATSAPP_VERIFY_TOKEN=
HAVILAH_WHATSAPP_ACCESS_TOKEN=
HAVILAH_WHATSAPP_PHONE_NUMBER_ID=
HAVILAH_WHATSAPP_BUSINESS_ACCOUNT_ID=
