# Havilah OS — Frontend Environment Variables
# ----------------------------------------------------------------------------
# Copy to .env.local for local dev. In Vercel, set these in
# Project Settings → Environment Variables.

# URL of the Havilah backend deployed on Railway.
# Example: https://havilah-backend.up.railway.app
# If unset, the dashboard shows mock data.
NEXT_PUBLIC_HAVILAH_API_URL=

# Optional bearer token for authenticated backend endpoints.
# Leave empty if you haven't enabled JWT auth on the backend yet.
NEXT_PUBLIC_HAVILAH_API_TOKEN=

# Local dev database (Prisma — used only by the Next.js starter, not Havilah backend)
DATABASE_URL=file:./dev.db
